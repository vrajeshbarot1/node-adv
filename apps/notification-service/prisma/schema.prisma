generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("NOTIFICATION_DB_URL")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  type      String   @default("INFO") // INFO, SUCCESS, WARNING, ERROR
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
