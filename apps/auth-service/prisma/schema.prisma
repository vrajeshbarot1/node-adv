generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("AUTH_DB_URL")
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  password        String
  refreshToken    String?
  twoFactorSecret String?
  twoFactorEnabled Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
