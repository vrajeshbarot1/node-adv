generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("USER_DB_URL")
}

enum Role {
  USER
  MANAGER
  ADMIN
}

model User {
  id          String   @id
  username    String?  @unique
  role        Role     @default(USER)
  permissions String[] @default([])
  managerId   String?  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
