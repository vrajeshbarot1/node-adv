generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("TASK_DB_URL")
}

enum Status {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      Status   @default(PENDING)
  userId      String   // ID of the user who owns the task
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
